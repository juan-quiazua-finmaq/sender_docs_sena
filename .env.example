# ====================================================================
# PLANTILLA DE VARIABLES DE ENTORNO - Docs SENA
# ====================================================================
# Copie este archivo como .env y complete los valores reales.
#   cp .env.example .env
# Nunca suba el archivo .env al repositorio (ya esta en .gitignore).
# ====================================================================

# --- Credenciales Gmail ---
# Contraseña de aplicacion de 16 caracteres generada por Google.
# Guia: https://myaccount.google.com/apppasswords
# Requiere Verificacion en 2 pasos activada.
GMAIL_APP_PASSWORD=

# Correo Gmail desde el que se envian los documentos al instructor.
# Ejemplo: tu-correo@gmail.com
GMAIL_SENDER=

# --- Destinatarios ---
# Correo del instructor SENA (modo produccion).
# Ejemplo: instructor@sena.edu.co
EMAIL_DESTINATARIO_PRODUCCION=

# Correo para pruebas (modo pruebas). Puede ser tuyo o de un companero.
# Ejemplo: tu-correo-pruebas@gmail.com
EMAIL_DESTINATARIO_PRUEBAS=

# Correo en copia fijo para monitorizacion.
# Ejemplo: tu-correo-cc@gmail.com
EMAIL_CC=

# --- Modo de operacion ---
# "pruebas"  -> envia a EMAIL_DESTINATARIO_PRUEBAS
# "produccion" -> envia a EMAIL_DESTINATARIO_PRODUCCION
EMAIL_MODO=pruebas

# --- Datos del usuario ---
# Tu nombre completo de aprendiz
APRENDIZ_NOMBRE=

# Nombre de la empresa donde realizas la etapa productiva
EMPRESA_NOMBRE=

# Nombre completo del instructor SENA de seguimiento
INSTRUCTOR_NOMBRE=
