# ====================================================================
# PLANTILLA DE VARIABLES DE ENTORNO - Docs SENA
# ====================================================================
# Copie este archivo como .env y complete los valores reales.
#   cp .env.example .env
# Nunca suba el archivo .env al repositorio (ya esta en .gitignore).
# ====================================================================

# --- Credenciales Gmail ---
# Contraseña de aplicacion de 16 caracteres generada por Google.
# Guia: https://myaccount.google.com/apppasswords
# Requiere Verificacion en 2 pasos activada.
GMAIL_APP_PASSWORD=

# Correo Gmail desde el que se envian los documentos al instructor.
# Ejemplo: tu-correo@gmail.com
GMAIL_SENDER=

# --- Destinatarios ---
# Correo del instructor SENA (modo produccion).
# Ejemplo: instructor@sena.edu.co
EMAIL_DESTINATARIO_PRODUCCION=

# Correo para pruebas (modo pruebas). Puede ser tuyo o de un companero.
# Ejemplo: tu-correo-pruebas@gmail.com
EMAIL_DESTINATARIO_PRUEBAS=

# Correo en copia fijo para monitorizacion.
# Ejemplo: tu-correo-cc@gmail.com
EMAIL_CC=

# --- Modo de operacion ---
# "pruebas"  -> envia a EMAIL_DESTINATARIO_PRUEBAS
# "produccion" -> envia a EMAIL_DESTINATARIO_PRODUCCION
EMAIL_MODO=pruebas

# --- Datos del usuario ---
# Tu nombre completo de aprendiz
APRENDIZ_NOMBRE=

# Nombre de la empresa donde realizas la etapa productiva
EMPRESA_NOMBRE=

# Nombre completo del instructor SENA de seguimiento
INSTRUCTOR_NOMBRE=

# --- Fechas de las Actas (OPCIONALES, configurables) ---
# El script detecta automaticamente que acta enviar segun la fecha de ejecucion.
# Estas fechas definen el momento "central" dentro de una ventana de tolerancia.
# Si no se definen, el script usa los defaults del proyecto.
# ADVERTENCIA: Si cambia estas fechas, el catch-up enviara todos los momentos
# no enviados hasta la fecha actual. Verifique contexto/actas_enviadas.json.

# Momento 1 (Planeacion). Default: 2026-04-08
ACTA_M1_FECHA=2026-04-08

# Momento 2 (Seguimiento). Default: 2026-06-22
ACTA_M2_FECHA=2026-06-22

# Momento 3 (Evaluacion Final). Default: 2026-10-07
ACTA_M3_FECHA=2026-10-07

# Ventana de tolerancia en dias (antes/despues de la fecha objetivo).
# Si la fecha actual esta dentro de esta ventana del momento, se activa.
# Default: 7
ACTA_VENTANA_DIAS=7

# --- Datos de la Etapa Productiva (OPCIONALES, para Momento 1) ---
# Estos campos se diligencian en la Tabla 2 del Word (Planeacion).
# Si quedan vacios, las celdas del Word quedaran en blanco.

# Fecha de inicio de la etapa productiva (formato DD/MM/AAAA).
# Ejemplo: 08/04/2026
FECHA_INICIO_ETAPA=

# Fecha de fin de la etapa productiva (formato DD/MM/AAAA).
# Ejemplo: 06/10/2026
FECHA_FIN_ETAPA=

# Fecha de afiliacion a la ARL (formato DD/MM/AAAA, opcional).
FECHA_AFILIACION_ARL=

# Numero de poliza ARL (si aplica).
ARL_NUMERO=

# Horario de la etapa (Diurno / Nocturno / Mixto).
HORARIO_ETAPA=Diurno
